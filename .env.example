# =============================================================================
# Horizon Member Portal - Environment Configuration
# =============================================================================
# Copy this file to .env and update values as needed.
# All variables prefixed with VITE_ are exposed to the client-side bundle.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
VITE_APP_TITLE=Horizon Member Portal

# -----------------------------------------------------------------------------
# Session Management
# -----------------------------------------------------------------------------
# Session timeout in milliseconds (default: 15 minutes = 900000)
VITE_SESSION_TIMEOUT_MS=900000

# Session warning prompt in milliseconds before timeout (default: 2 minutes = 120000)
VITE_SESSION_WARNING_MS=120000

# -----------------------------------------------------------------------------
# Analytics & Tracking
# -----------------------------------------------------------------------------
# Enable Glassbox session replay (true/false)
VITE_GLASSBOX_ENABLED=false

# -----------------------------------------------------------------------------
# Support Contact Information
# -----------------------------------------------------------------------------
VITE_SUPPORT_EMAIL=support@horizonhealthcare.com
VITE_SUPPORT_PHONE=1-800-555-0199
VITE_SUPPORT_CHAT_URL=https://support.horizonhealthcare.com/chat

# -----------------------------------------------------------------------------
# External Service URLs
# -----------------------------------------------------------------------------
VITE_DOCTOR_FINDER_URL=https://www.horizonhealthcare.com/find-a-doctor